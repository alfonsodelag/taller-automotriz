---
import Button from "@/components/Button.astro";
---

<section class="section-pad bg-lavender">
  <div class="container-page grid items-center gap-12 lg:grid-cols-2">
    <!-- Imágenes lado izquierdo -->
    <div class="grid grid-cols-2 gap-4">
      <img
        class="h-72 w-full rounded-xl object-cover shadow-soft"
        src="/images/about-video.jpg"
        alt="Mecánico trabajando en el taller Gálvez Car Services"
        loading="lazy"
      />
      <img
        class="mt-10 h-72 w-full rounded-xl object-cover shadow-soft"
        src="/images/contact-pic.jpg"
        alt="Interior del taller automotriz Gálvez Car Services en La Carrasquilla, Panamá"
        loading="lazy"
      />
    </div>

    <!-- Texto lado derecho -->
    <div>
      <p class="eyebrow">Sobre el taller</p>
      <h2 class="mt-4 font-display text-4xl font-black uppercase leading-tight tracking-tight text-white sm:text-5xl">
        TALLER FAMILIAR CON MÁS DE <span class="text-rose">25 AÑOS</span> EN PANAMÁ
      </h2>
      <p class="mt-6 text-base leading-7 text-shell/75">
        Gálvez Car Services es atendido directamente por sus propios dueños, en La Carrasquilla, Ciudad de Panamá. Trato directo, diagnóstico claro y trabajo garantizado — sin intermediarios.
      </p>

      <ul class="mt-8 grid gap-3 sm:grid-cols-2">
        {[
          "Atendido por sus propios dueños",
          "BMW y carros japoneses",
          "Diagnóstico claro y honesto",
          "Un solo taller para todo",
        ].map((point) => (
          <li class="flex items-start gap-3 text-sm text-shell/80">
            <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-rose text-white text-xs font-bold">✓</span>
            {point}
          </li>
        ))}
      </ul>

      <div class="mt-8">
        <Button href="/about" label="Conocer más sobre nosotros" />
      </div>
    </div>
  </div>
</section>

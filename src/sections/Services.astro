---
import SectionTitle from "@/components/SectionTitle.astro";
import { services } from "@/content/services";

const featured = services.filter((service) => service.featured).slice(0, 3);
const items = featured.length ? featured : services.slice(0, 3);
---

<section class="section-pad bg-white">
  <div class="container-page">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <SectionTitle
        eyebrow="Servicios"
        title="Todo lo que tu vehículo necesita en un solo taller."
        intro="Mecánica, chapistería, pintura, aire acondicionado, detailing y más. Diagnóstico honesto y soluciones concretas."
      />
      <a class="btn-secondary md:mb-1" href="/services">Ver todos</a>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {items.map((service) => (
        <article class="card overflow-hidden">
          <img class="h-56 w-full object-cover" src={service.image} alt={service.title} loading="lazy" />
          <div class="p-6">
            <h3 class="font-display text-2xl font-bold text-ink">{service.title}</h3>
            <p class="mt-3 text-sm leading-6 text-cocoa">{service.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

---
import SectionTitle from "@/components/SectionTitle.astro";
import { services } from "@/content/services";
---

<section class="section-pad bg-white">
  <div class="container-page">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <SectionTitle
        eyebrow="Lo que hacemos"
        titleHtml='NUESTROS <span class="text-rose">SERVICIOS</span>'
        intro="Mecánica, chapistería, pintura, A/C, detailing y más — todo bajo el mismo techo."
      />
      <a class="btn-secondary shrink-0 self-start lg:mb-1" href="/services">Ver todos los servicios</a>
    </div>
    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {services.map((service) => (
        <article class="group overflow-hidden rounded-lg border border-shell bg-white shadow-card transition hover:shadow-soft">
          <div class="relative overflow-hidden">
            <img
              class="h-44 w-full object-cover transition duration-500 group-hover:scale-105"
              src={service.image}
              alt={service.title}
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-lavender/30 to-transparent opacity-0 transition duration-300 group-hover:opacity-100"></div>
          </div>
          <div class="p-5">
            <h3 class="font-display text-base font-bold uppercase leading-tight text-ink">{service.title}</h3>
            <p class="mt-2 text-sm leading-6 text-cocoa">{service.description}</p>
            <a
              class="mt-4 inline-flex items-center gap-1 text-sm font-bold uppercase tracking-wide text-rose transition hover:text-rose-dark"
              href={`/services/${service.slug}`}
            >
              Ver detalles <span aria-hidden="true">→</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

---
import SectionTitle from "@/components/SectionTitle.astro";
import { posts } from "@/content/blog";
---

<section class="section-pad bg-white">
  <div class="container-page">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <SectionTitle eyebrow="Blog" title="Consejos y guías para cuidar mejor tu vehículo." />
      <a class="btn-secondary md:mb-1" href="/blog">Ver blog</a>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {posts.map((post) => (
        <article class="card overflow-hidden">
          <img class="h-52 w-full object-cover" src={post.image} alt={post.title} loading="lazy" />
          <div class="p-6">
            <time class="text-xs font-semibold uppercase tracking-[0.14em] text-sage" datetime={post.date}>{post.date}</time>
            <h3 class="mt-3 font-display text-2xl font-bold text-ink">{post.title}</h3>
            <p class="mt-3 text-sm leading-6 text-cocoa">{post.excerpt}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

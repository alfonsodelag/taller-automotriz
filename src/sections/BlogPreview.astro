---
import SectionTitle from "@/components/SectionTitle.astro";
import { sanityClient, urlFor } from "@/lib/sanity";

const posts = await sanityClient.fetch<{
  title: string;
  slug: string;
  publishedAt: string;
  excerpt: string;
  image: any;
}[]>(
  `*[_type == "post" && category in ["Mecánica","Chapistería","Pintura","Pintura y chapistería","Aire acondicionado","Detailing","BMW","Carros japoneses","Mantenimiento"]] | order(publishedAt desc) [0...3] {
    title,
    "slug": slug.current,
    publishedAt,
    excerpt,
    image
  }`
);

function formatDate(iso: string) {
  return new Date(iso).toLocaleDateString("es-PA", {
    year: "numeric", month: "long", day: "numeric",
  });
}
---

<section class="section-pad bg-white">
  <div class="container-page">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <SectionTitle eyebrow="Blog" title="Consejos y guías para cuidar mejor tu vehículo." />
      <a class="btn-secondary md:mb-1" href="/blog">Ver todos los artículos</a>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {posts.map((post) => (
        <article class="card overflow-hidden group">
          <div class="relative overflow-hidden">
            <img
              class="h-52 w-full object-cover transition duration-300 group-hover:scale-105"
              src={post.image ? urlFor(post.image).width(800).height(420).url() : "/images/blog/blog-1.jpg"}
              alt={post.title}
              loading="lazy"
            />
            <div class="absolute bottom-0 left-0 h-1 w-full bg-rose"></div>
          </div>
          <div class="p-6">
            <time class="text-xs font-bold uppercase tracking-[0.14em] text-rose" datetime={post.publishedAt}>
              {formatDate(post.publishedAt)}
            </time>
            <h3 class="mt-3 font-display text-xl font-bold leading-snug text-ink">{post.title}</h3>
            <p class="mt-3 text-sm leading-6 text-cocoa">{post.excerpt}</p>
            <a
              class="mt-5 inline-flex items-center gap-1 text-sm font-bold uppercase tracking-wide text-rose transition hover:text-rose-dark"
              href={`/blog/${post.slug}`}
            >
              Leer artículo <span aria-hidden="true">→</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

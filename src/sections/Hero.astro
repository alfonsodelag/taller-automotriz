---
import Button from "@/components/Button.astro";
import { whatsappUrl } from "@/config/site";
---

<section class="relative overflow-hidden bg-lavender">
  <div class="container-page relative grid min-h-[calc(100vh-5rem)] items-center gap-10 py-16 lg:grid-cols-2 lg:py-20">
    <!-- Texto izquierdo -->
    <div class="max-w-2xl">
      <p class="eyebrow">Taller automotriz · Ciudad de Panamá</p>
      <h1 class="mt-5 font-display text-5xl font-black uppercase leading-[1.05] tracking-tight text-white sm:text-6xl lg:text-7xl">
        TU TALLER<br />
        <span class="text-rose">TODO EN UNO</span><br />
        EN PANAMÁ
      </h1>
      <p class="mt-6 text-lg leading-8 text-shell/80">
        Mecánica general, chapistería, pintura, A/C, detailing y diagnóstico computarizado. Atendido por sus propios dueños con más de 25 años de experiencia.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <Button href={whatsappUrl} label="Agendar por WhatsApp" />
        <Button href="/services" label="Ver todos los servicios" variant="outline" />
      </div>
    </div>

    <!-- Imagen derecha -->
    <div class="relative hidden lg:block">
      <div class="absolute -inset-4 rounded-2xl bg-rose/10 blur-3xl"></div>
      <img
        class="relative h-[38rem] w-full rounded-xl object-cover shadow-soft"
        src="/images/hero-bg.jpg"
        alt="Taller Gálvez Car Services – mecánica, chapistería y pintura en Ciudad de Panamá"
      />
      <!-- Badge superpuesto -->
      <div class="absolute bottom-6 left-6 max-w-[260px] rounded-xl border border-white/10 bg-lavender/90 p-5 backdrop-blur-sm">
        <p class="text-xs font-bold uppercase tracking-[0.18em] text-rose">Diagnóstico honesto</p>
        <p class="mt-2 text-sm leading-6 text-shell">
          Te decimos qué tiene tu vehículo, qué hay que hacer y cuánto cuesta — antes de empezar.
        </p>
      </div>
    </div>
  </div>

  <!-- Línea roja inferior -->
  <div class="h-1 w-full bg-rose"></div>
</section>

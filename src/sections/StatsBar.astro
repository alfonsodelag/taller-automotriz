---
const stats = [
  { value: "25+",  label: "Años de experiencia" },
  { value: "8",    label: "Servicios disponibles" },
  { value: "BMW",  label: "Especialistas en europeos" },
  { value: "L–S",  label: "Disponible lunes a sábado" },
];
---

<section class="bg-sage py-14">
  <div class="container-page">
    <dl class="grid grid-cols-2 gap-8 md:grid-cols-4">
      {stats.map((stat, i) => (
        <div class:list={["text-center", i < stats.length - 1 && "md:border-r md:border-white/10"]}>
          <dt class="font-display text-5xl font-black text-rose">{stat.value}</dt>
          <dd class="mt-3 text-xs font-bold uppercase tracking-[0.16em] text-shell/70">{stat.label}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>

---
import SectionTitle from "@/components/SectionTitle.astro";
import { testimonials } from "@/content/testimonials";
---

<section class="section-pad bg-white">
  <div class="container-page">
    <SectionTitle
      eyebrow="Opiniones"
      titleHtml='LO QUE DICEN <span class="text-rose">NUESTROS CLIENTES</span>'
      intro="Clientes que han confiado su vehículo a Gálvez Car Services y regresan."
      align="center"
    />
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {testimonials.map((item) => (
        <figure class="card flex flex-col p-6">
          <!-- Estrellas -->
          <div class="mb-4 flex gap-0.5 text-yellow-400" aria-label="5 estrellas">
            {Array.from({ length: 5 }).map(() => <span aria-hidden="true">★</span>)}
          </div>
          <blockquote class="flex-1 text-base leading-7 text-cocoa">"{item.quote}"</blockquote>
          <figcaption class="mt-5 border-t border-shell pt-5">
            <p class="font-bold text-ink">{item.name}</p>
            <p class="text-sm font-medium uppercase tracking-wide text-rose">{item.treatment}</p>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

---
import SectionTitle from "@/components/SectionTitle.astro";
import { faqs } from "@/content/faqs";
---

<section class="section-pad bg-cream">
  <div class="container-page grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
    <SectionTitle
      eyebrow="Preguntas frecuentes"
      title="Respuestas directas antes de venir al taller."
      intro="Si tienes dudas sobre servicios, horarios, presupuestos o cómo trabajamos, aquí están las respuestas más comunes."
    />
    <div class="space-y-3">
      {faqs.map((faq) => (
        <details class="group rounded-lg border border-shell bg-white shadow-card">
          <summary class="flex cursor-pointer items-center justify-between p-5 font-bold text-ink">
            {faq.question}
            <span class="ml-4 shrink-0 text-rose transition group-open:rotate-45">+</span>
          </summary>
          <p class="border-t border-shell px-5 pb-5 pt-4 text-sm leading-6 text-cocoa">{faq.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>

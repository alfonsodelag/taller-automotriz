---
import SectionTitle from "@/components/SectionTitle.astro";
import { doctors } from "@/content/doctors";
---

<section class="section-pad bg-shell">
  <div class="container-page">
    <SectionTitle
      eyebrow="Quiénes somos"
      title="Trato directo, experiencia real y compromiso con tu vehículo."
      intro="En Gálvez Car Services conoces a quién hace el trabajo. Los propietarios están presentes todos los días para atenderte y responder por cada servicio."
      align="center"
    />
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {doctors.map((member) => (
        <article class="rounded-lg bg-white p-4 shadow-soft">
          <img class="aspect-[4/5] w-full rounded-md object-cover" src={member.image} alt={member.name} loading="lazy" />
          <div class="p-3">
            <h3 class="font-display text-2xl font-bold text-ink">{member.name}</h3>
            <p class="mt-1 text-sm font-semibold text-sage">{member.role}</p>
            <p class="mt-3 text-sm leading-6 text-cocoa">{member.bio}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

---
import SectionTitle from "@/components/SectionTitle.astro";

const reasons = [
  {
    num: "01",
    title: "Atendido por sus propios dueños",
    body: "Sabes con quién hablas y quién responde. Los dueños del taller están presentes todos los días — sin intermediarios ni excusas."
  },
  {
    num: "02",
    title: "Servicio completo bajo un techo",
    body: "Mecánica, chapistería, pintura, A/C y detailing en un solo lugar. Sin andar de taller en taller perdiendo tiempo y dinero."
  },
  {
    num: "03",
    title: "Especialistas en BMW y japoneses",
    body: "Experiencia específica en mecánica y electrónica de BMW, Toyota, Honda, Nissan y otras marcas europeas y japonesas."
  },
  {
    num: "04",
    title: "Diagnóstico claro y honesto",
    body: "Te explicamos qué tiene tu vehículo antes de empezar. Sin trabajo innecesario y sin sorpresas en el presupuesto final."
  }
];
---

<section class="section-pad bg-shell">
  <div class="container-page">
    <SectionTitle
      eyebrow="Razones para elegirnos"
      titleHtml='¿POR QUÉ <span class="text-rose">ELEGIRNOS?</span>'
      intro="Lo que nos diferencia de otros talleres en Ciudad de Panamá."
      align="center"
    />
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {reasons.map((reason) => (
        <article class="card p-6">
          <div class="font-display text-5xl font-black text-rose/20">{reason.num}</div>
          <h3 class="mt-4 font-display text-base font-bold uppercase leading-snug text-ink">{reason.title}</h3>
          <p class="mt-3 text-sm leading-6 text-cocoa">{reason.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

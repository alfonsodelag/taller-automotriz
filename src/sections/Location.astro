---
import SectionTitle from "@/components/SectionTitle.astro";
import { siteConfig, whatsappUrl } from "@/config/site";
---

<section class="section-pad bg-cream">
  <div class="container-page grid items-center gap-10 lg:grid-cols-2">
    <!-- Google Maps embed -->
    <div class="h-96 overflow-hidden rounded-xl shadow-soft border border-shell">
      <iframe
        src="https://maps.google.com/maps?q=Calle+65+C+Este%2C+La+Carrasquilla%2C+Ciudad+de+Panama&output=embed&hl=es&z=16"
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title={`Ubicación de ${siteConfig.businessName} en Google Maps`}
      ></iframe>
    </div>

    <!-- Info -->
    <div>
      <SectionTitle
        eyebrow="Ubicación"
        title="Estamos en La Carrasquilla, Ciudad de Panamá."
        intro="Fácil acceso desde Calle 65 C Este. Si tienes dudas de cómo llegar, escríbenos por WhatsApp y te orientamos."
      />
      <div class="mt-8 rounded-lg border border-shell bg-white p-6 shadow-card">
        <div class="flex items-start gap-3">
          <div class="mt-1 h-4 w-1 shrink-0 rounded bg-rose"></div>
          <div>
            <p class="font-bold text-ink">{siteConfig.address}</p>
            <p class="mt-2 text-sm leading-6 text-cocoa">{siteConfig.hours.weekdays}</p>
            <p class="text-sm leading-6 text-cocoa">{siteConfig.hours.saturday}</p>
            <p class="text-sm leading-6 text-cocoa">{siteConfig.hours.sunday}</p>
          </div>
        </div>
      </div>
      <div class="mt-6 flex flex-wrap gap-3">
        <a class="btn-primary" href={whatsappUrl}>Cómo llegar – WhatsApp</a>
        <a
          class="btn-secondary"
          href="https://maps.google.com/maps?q=Calle+65+C+Este%2C+La+Carrasquilla%2C+Ciudad+de+Panama"
          target="_blank"
          rel="noopener noreferrer"
        >
          Abrir en Google Maps
        </a>
      </div>
    </div>
  </div>
</section>

---
import { siteConfig, whatsappUrl } from "@/config/site";

const navItems = [
  { href: "/", label: "Inicio" },
  { href: "/about", label: "Nosotros" },
  { href: "/services", label: "Servicios" },
  { href: "/blog", label: "Blog" },
  { href: "/contact", label: "Contacto" }
];
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-lavender">
  <div class="hidden bg-lavender py-2 text-xs text-shell lg:block">
    <div class="container-page flex items-center justify-between">
      <p>{siteConfig.phone} · {siteConfig.address}</p>
      <p>{siteConfig.hours.weekdays}</p>
    </div>
  </div>
  <div class="container-page flex min-h-20 items-center justify-between gap-4">
    <a href="/" class="flex items-center gap-2" aria-label={`${siteConfig.businessName} inicio`}>
      <img src="/images/logo.png" alt={`Logo ${siteConfig.businessName}`} class="h-14 w-auto object-contain" />
    </a>

    <nav class="hidden items-center gap-7 text-sm font-medium text-shell lg:flex" aria-label="Navegación principal">
      {navItems.map((item) => (
        <a class="transition hover:text-rose" href={item.href}>{item.label}</a>
      ))}
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      <a class="btn-outline px-4 py-2.5" href="/contact">Cotizar</a>
      <a class="btn-primary px-4 py-2.5" href={whatsappUrl}>WhatsApp</a>
    </div>

    <details class="relative lg:hidden">
      <summary class="flex size-11 cursor-pointer list-none items-center justify-center rounded-md border border-white/20 text-white" aria-label="Abrir menú">
        <span class="text-2xl leading-none">≡</span>
      </summary>
      <div class="absolute right-0 mt-3 w-72 rounded-lg border border-white/10 bg-lavender p-4 shadow-soft">
        <nav class="grid gap-2 text-sm font-medium text-shell" aria-label="Navegación móvil">
          {navItems.map((item) => (
            <a class="rounded-md px-3 py-2 hover:bg-sage hover:text-white" href={item.href}>{item.label}</a>
          ))}
        </nav>
        <a class="btn-primary mt-4 w-full" href={whatsappUrl}>Escribir por WhatsApp</a>
      </div>
    </details>
  </div>
</header>

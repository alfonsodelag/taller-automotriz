---
type Props = {
  eyebrow: string;
  title?: string;
  titleHtml?: string;
  intro?: string;
  align?: "left" | "center";
  dark?: boolean;
};

const { eyebrow, title, titleHtml, intro, align = "left", dark = false } = Astro.props;
---

<div class:list={["max-w-3xl", align === "center" && "mx-auto text-center"]}>
  <p class="eyebrow">{eyebrow}</p>
  <h2 class:list={[
    "mt-3 font-display text-3xl font-bold uppercase leading-tight tracking-tight sm:text-4xl",
    dark ? "text-white" : "text-ink"
  ]}>
    {titleHtml ? <Fragment set:html={titleHtml} /> : title}
  </h2>
  {intro && (
    <p class:list={["mt-4 text-base leading-7", dark ? "text-shell/70" : "text-cocoa"]}>
      {intro}
    </p>
  )}
</div>

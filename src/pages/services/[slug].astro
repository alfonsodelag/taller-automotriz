---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { services } from "@/content/services";
import { whatsappUrl } from "@/config/site";

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
---

<BaseLayout
  title={`${service.title} | Gálvez Car Services`}
  description={service.description}
>
  <!-- Hero del servicio -->
  <div class="relative bg-lavender overflow-hidden">
    <img
      class="absolute inset-0 h-full w-full object-cover opacity-30"
      src={service.image}
      alt={service.title}
    />
    <div class="relative z-10 container-page py-24 md:py-32">
      <span class="mb-4 inline-block rounded bg-rose px-3 py-1 text-xs font-bold uppercase tracking-widest text-white">
        Servicio
      </span>
      <h1 class="font-display text-3xl font-bold uppercase leading-tight text-white md:text-5xl max-w-3xl">
        {service.title}
      </h1>
    </div>
    <div class="absolute bottom-0 left-0 h-1 w-full bg-rose"></div>
  </div>

  <!-- Contenido del servicio -->
  <section class="section-pad bg-cream">
    <div class="container-page">
      <div class="grid gap-10 lg:grid-cols-2 lg:items-start">
        <!-- Descripción + imagen -->
        <div>
          <p class="mb-3 font-display text-sm font-bold uppercase tracking-[0.2em] text-rose">
            Descripción
          </p>
          <p class="text-lg leading-relaxed text-ink/80">{service.description}</p>

          <img
            class="mt-8 rounded-xl w-full h-64 object-cover shadow-soft"
            src={service.image}
            alt={service.title}
            loading="lazy"
          />

          <div class="mt-8 flex flex-wrap gap-4">
            <a
              class="btn-primary"
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              Solicitar este servicio
            </a>
            <a class="btn-secondary" href="/services">← Todos los servicios</a>
          </div>
        </div>

        <!-- Qué incluye -->
        <div class="rounded-xl border border-shell bg-white p-8 shadow-card">
          <p class="mb-6 font-display text-xl font-bold uppercase text-ink">¿Qué incluye?</p>
          <ul class="space-y-4">
            {service.features.map((feature) => (
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-rose/10 text-xs font-bold text-rose">
                  ✔
                </span>
                <span class="text-cocoa">{feature}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="section-pad bg-lavender">
    <div class="container-page text-center">
      <p class="font-display text-3xl font-bold uppercase text-white">
        ¿Listo para agendar?
      </p>
      <p class="mx-auto mt-4 max-w-xl text-shell/80">
        Más de 25 años de experiencia nos respaldan. Contáctanos hoy y te atendemos directamente.
      </p>
      <a
        class="btn-primary mt-8 inline-block"
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        Contactar por WhatsApp
      </a>
    </div>
  </section>
</BaseLayout>

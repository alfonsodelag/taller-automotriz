---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionTitle from "@/components/SectionTitle.astro";
import Contact from "@/sections/Contact.astro";
import { posts } from "@/content/blog";
---

<BaseLayout
  title="Blog | Gálvez Car Services – Consejos para cuidar tu vehículo"
  description="Artículos y guías sobre mantenimiento automotriz, diagnóstico, chapistería, pintura, aire acondicionado y cuidado de BMW y carros japoneses en Panamá."
>
  <section class="section-pad bg-white">
    <div class="container-page">
      <SectionTitle
        eyebrow="Blog"
        title="Consejos prácticos para cuidar mejor tu vehículo."
        intro="Guías sobre mantenimiento, señales de alerta, diagnóstico y cómo sacarle más vida a tu carro en el clima y las condiciones de Panamá."
        align="center"
      />
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {posts.map((post) => (
          <article class="card overflow-hidden">
            <img class="h-56 w-full object-cover" src={post.image} alt={post.title} loading="lazy" />
            <div class="p-6">
              <time class="text-xs font-semibold uppercase tracking-[0.14em] text-sage" datetime={post.date}>{post.date}</time>
              <h2 class="mt-3 font-display text-2xl font-bold text-ink">{post.title}</h2>
              <p class="mt-3 text-sm leading-6 text-cocoa">{post.excerpt}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
  <Contact />
</BaseLayout>
